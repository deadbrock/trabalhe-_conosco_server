# Copie para server/.env
# Use a URL pública do Postgres no Railway (aba Connect → Public network), não *.railway.internal

DATABASE_URL=postgresql://usuario:senha@HOST_PUBLICO:PORTA/railway

JWT_SECRET=defina-um-segredo-longo-em-producao
PORT=3333

# Opcional: forçar sem SSL (só Postgres local)
# DATABASE_SSL=false
